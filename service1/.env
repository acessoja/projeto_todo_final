# Serviço 1 – API de Tarefas
# Banco de dados (SQLite para dev)
DATABASE_URL="file:./prisma/dev.db"

# Porta do servidor Express
PORT=3001

# Ambiente
NODE_ENV=development

# URL do Serviço 2 (Gerador de Logs) — Laravel na porta 8001
SERVICE2_URL=http://localhost:8001

# URL do Serviço 3 (Analisador) — FastAPI na porta 8000
SERVICE3_URL=http://localhost:8000

# CORS — permite frontend na porta 5500 (Live Server) e 3000
CORS_ORIGIN=*
