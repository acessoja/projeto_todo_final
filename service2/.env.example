APP_NAME="Servico2-Logs"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Banco de Dados ───────────────────────────────────────────────────────
# Ajuste para o seu banco. MySQL recomendado para produção.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=service2_logs
DB_USERNAME=root
DB_PASSWORD=

# ─── Integração com outros serviços ──────────────────────────────────────
# URL base do Serviço 1 (caso o Serviço 2 precise consultar de volta)
SERVICE1_URL=http://localhost:3000

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
